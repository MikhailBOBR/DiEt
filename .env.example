APP_ENV=development
RELEASE_VERSION=1.0.0-rc.3
SERVICE_NAME=food-diary-app
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
PORT=8080
JWT_SECRET=replace_with_random_secret_at_least_32_characters
LOG_LEVEL=info
LOG_PRETTY=false
TRUST_PROXY=false
REQUEST_ID_HEADER=X-Request-ID
SHUTDOWN_TIMEOUT_MS=10000
SERVER_REQUEST_TIMEOUT_MS=300000
SERVER_HEADERS_TIMEOUT_MS=60000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000

DB_PROVIDER=postgres
DB_PATH=./server/data/app.db
DATABASE_URL=
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nutritrack
DB_USER=nutritrack
DB_PASSWORD=replace_with_local_database_password
DB_POOL_MAX=12
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
REDIS_URL=redis://redis:6379

DEMO_USER_EMAIL=demo@nutritrack.local
DEMO_USER_PASSWORD=replace_with_demo_password
DEMO_USER_NAME=Demo User
ADMIN_USER_EMAIL=admin@nutritrack.local
ADMIN_USER_PASSWORD=replace_with_admin_password
ADMIN_USER_NAME=System Admin
